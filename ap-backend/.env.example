# AP Rides Backend — Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/ap_db

# JWT Authentication
JWT_SECRET=ap-rides-super-secret-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# Google Maps (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_MAPS_API_KEY=

# Firebase (path to your firebase-key.json file)
FIREBASE_CREDENTIALS_PATH=firebase-key.json

# Cloudinary (get from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App Settings
APP_NAME=AP Rides
APP_ENV=development
DEBUG=true

# Ride Settings
RIDE_OFFER_TIMEOUT_SECONDS=60
MAX_STAND_SEARCH_RADIUS_KM=5
MAX_RIDE_OFFERS_PER_RIDE=10

# Dev OTP (fixed OTP for development - remove in production!)
DEV_OTP=1234
